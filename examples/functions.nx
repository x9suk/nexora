// Functions in Nexora

func greet(name) {
    print "Hello, " + name + "!"
}

func add(a, b) {
    return a + b
}

func factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

// Use the functions
greet("Nexora")
print "5 + 3 = " + str(add(5, 3))
print "5! = " + str(factorial(5))
