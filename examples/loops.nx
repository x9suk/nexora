// Loops in Nexora

// While loop
print "Counting with while:"
let i = 1
while i <= 5 {
    print "Count: " + str(i)
    i = i + 1
}

// For loop
print ""
print "Fruits:"
let fruits = ["apple", "banana", "cherry"]
for fruit in fruits {
    print "Fruit: " + fruit
}

// For loop with numbers
print ""
print "Numbers:"
for num in [1, 2, 3, 4, 5] {
    print "Number: " + str(num)
}
