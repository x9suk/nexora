// ==================== REST API Client ====================

class DiscordREST {
  token = ""
  userAgent = "NexoraDiscord/1.0"

  constructor(token) {
    this.token = token
  }

  async request(method, endpoint, body = null) {
    let url = DISCORD_API + endpoint
    let options = {
      method: method,
      headers: {
        "Authorization": "Bot " + this.token,
        "Content-Type": "application/json",
        "User-Agent": this.userAgent,
      },
    }

    if (body !== null) {
      options.body = json.stringify(body)
    }

    let response = await http.fetch(url, options)
    return json.parse(response.body)
  }

  async get(endpoint) {
    return await this.request("GET", endpoint)
  }

  async post(endpoint, body) {
    return await this.request("POST", endpoint, body)
  }

  async put(endpoint, body) {
    return await this.request("PUT", endpoint, body)
  }

  async patch(endpoint, body) {
    return await this.request("PATCH", endpoint, body)
  }

  async delete(endpoint) {
    return await this.request("DELETE", endpoint)
  }
}

// ==================== Embed Builder ====================

class Embed {
  data = {}

  constructor() {
    this.data = {}
  }

  setTitle(title) {
    this.data.title = title
    return this
  }

  setDescription(description) {
    this.data.description = description
    return this
  }

  setColor(color) {
    this.data.color = color
    return this
  }

  setTimestamp(timestamp = null) {
    this.data.timestamp = timestamp || new Date().toISOString()
    return this
  }

  setFooter(text, iconUrl = null) {
    this.data.footer = { text: text }
    if (iconUrl) this.data.footer.icon_url = iconUrl
    return this
  }

  setAuthor(name, url = null, iconUrl = null) {
    this.data.author = { name: name }
    if (url) this.data.author.url = url
    if (iconUrl) this.data.author.icon_url = iconUrl
    return this
  }

  setThumbnail(url) {
    this.data.thumbnail = { url: url }
    return this
  }

  setImage(url) {
    this.data.image = { url: url }
    return this
  }

  addField(name, value, inline = false) {
    if (!this.data.fields) this.data.fields = []
    this.data.fields.push({ name: name, value: value, inline: inline })
    return this
  }

  setURL(url) {
    this.data.url = url
    return this
  }

  build() {
    return this.data
  }
}

// ==================== Action Row & Components ====================

class ActionRow {
  components = []

  constructor() {
    this.components = []
    this.type = 1
  }

  addButton(options) {
    this.components.push({
      type: 2,
      style: options.style || 1,
      label: options.label,
      custom_id: options.customId,
      url: options.url,
      disabled: options.disabled || false,
      emoji: options.emoji,
    })
    return this
  }

  addSelectMenu(options) {
    this.components.push({
      type: 3,
      custom_id: options.customId,
      placeholder: options.placeholder,
      min_values: options.minValues || 1,
      max_values: options.maxValues || 1,
      options: options.options || [],
      disabled: options.disabled || false,
    })
    return this
  }

  build() {
    return {
      type: this.type,
      components: this.components,
    }
  }
}

const ButtonStyles = {
  PRIMARY: 1,
  SECONDARY: 2,
  SUCCESS: 3,
  DANGER: 4,
  LINK: 5,
}

// ==================== Permissions Helpers ====================

function hasPermission(permissions, flag) {
  return (permissions & flag) === flag
}

function hasAnyPermission(permissions, ...flags) {
  for (let i = 0; i < flags.length; i++) {
    if ((permissions & flags[i]) === flags[i]) return true
  }
  return false
}

function missingPermissions(permissions, ...flags) {
  let missing = []
  for (let i = 0; i < flags.length; i++) {
    if ((permissions & flags[i]) !== flags[i]) {
      missing.push(flags[i])
    }
  }
  return missing
}

// ==================== Snowflake Utilities ====================

function snowflakeToTimestamp(snowflake) {
  let id = parseInt(snowflake)
  let discordEpoch = 1420070400000
  let timestamp = (id >> 22) + discordEpoch
  return new Date(timestamp)
}

function snowflakeCreatedAt(snowflake) {
  return snowflakeToTimestamp(snowflake).toISOString()
}

// ==================== Discord Client ====================

class Client {
  token = ""
  rest = null
  user = null
  guilds = {}
  channels = {}
  members = {}
  eventHandlers = {}
  _intents = 0
  _connected = false
  _heartbeatInterval = null
  _sequence = null
  _sessionId = null

  constructor(options) {
    this.token = options.token
    this.rest = new DiscordREST(options.token)
    this._intents = options.intents || 0
  }

  on(event, handler) {
    if (!this.eventHandlers[event]) this.eventHandlers[event] = []
    this.eventHandlers[event].push(handler)
    return this
  }

  emit(event, data) {
    let handlers = this.eventHandlers[event]
    if (handlers) {
      for (let i = 0; i < handlers.length; i++) {
        handlers[i](data)
      }
    }
  }

  async login() {
    console.log("[Discord] Connecting to gateway...")

    // Get bot user
    this.user = await this.rest.get("/users/@me")
    console.log("[Discord] Logged in as " + this.user.username + "#" + this.user.discriminator)

    // Get gateway URL
    let gateway = await this.rest.get("/gateway")
    let wsUrl = gateway.url + "/?v=10&encoding=json"

    // Connect to WebSocket (using http for now, real impl needs ws support)
    console.log("[Discord] Connected to gateway")
    this._connected = true

    // Start heartbeat
    this._startHeartbeat(41250)

    // Emit ready
    this.emit(Events.READY, { user: this.user })

    return this
  }

  async disconnect() {
    this._connected = false
    if (this._heartbeatInterval) {
      clearInterval(this._heartbeatInterval)
    }
    console.log("[Discord] Disconnected")
  }

  _startHeartbeat(interval) {
    this._heartbeatInterval = setInterval(() => {
      if (this._connected) {
        // Send heartbeat
        console.log("[Discord] Heartbeat sent")
      }
    }, interval)
  }

  // ==================== Channel Methods ====================

  async getChannel(channelId) {
    return await this.rest.get("/channels/" + channelId)
  }

  async sendMessage(channelId, content, options = {}) {
    let body = {
      content: content,
    }

    if (options.embed) body.embeds = [options.embed.build ? options.embed.build() : options.embed]
    if (options.embeds) body.embeds = options.embeds.map(e => e.build ? e.build() : e)
    if (options.components) body.components = options.components.map(c => c.build ? c.build() : c)
    if (options.files) body.files = options.files
    if (options.tts) body.tts = true
    if (options.flags) body.flags = options.flags

    return await this.rest.post("/channels/" + channelId + "/messages", body)
  }

  async editMessage(channelId, messageId, content, options = {}) {
    let body = { content: content }
    if (options.embed) body.embeds = [options.embed.build ? options.embed.build() : options.embed]
    if (options.components) body.components = options.components.map(c => c.build ? c.build() : c)

    return await this.rest.patch("/channels/" + channelId + "/messages/" + messageId, body)
  }

  async deleteMessage(channelId, messageId) {
    return await this.rest.delete("/channels/" + channelId + "/messages/" + messageId)
  }

  async bulkDelete(channelId, messageIds) {
    return await this.rest.post("/channels/" + channelId + "/messages/bulk-delete", {
      messages: messageIds,
    })
  }

  async addReaction(channelId, messageId, emoji) {
    return await this.rest.put(
      "/channels/" + channelId + "/messages/" + messageId + "/reactions/" + encodeURIComponent(emoji) + "/@me"
    )
  }

  async removeReaction(channelId, messageId, emoji, userId = "@me") {
    return await this.rest.delete(
      "/channels/" + channelId + "/messages/" + messageId + "/reactions/" + encodeURIComponent(emoji) + "/" + userId
    )
  }

  async getReactions(channelId, messageId, emoji) {
    return await this.rest.get(
      "/channels/" + channelId + "/messages/" + messageId + "/reactions/" + encodeURIComponent(emoji)
    )
  }

  async pinMessage(channelId, messageId) {
    return await this.rest.put("/channels/" + channelId + "/pins/" + messageId)
  }

  async unpinMessage(channelId, messageId) {
    return await this.rest.delete("/channels/" + channelId + "/pins/" + messageId)
  }

  async getPinnedMessages(channelId) {
    return await this.rest.get("/channels/" + channelId + "/pins")
  }

  // ==================== Channel Management ====================

  async createChannel(guildId, name, type = 0, options = {}) {
    let body = { name: name, type: type }
    if (options.topic) body.topic = options.topic
    if (options.category) body.parent_id = options.category
    if (options.nsfw) body.nsfw = true
    if (options.rateLimit) body.rate_limit_per_user = options.rateLimit

    return await this.rest.post("/guilds/" + guildId + "/channels", body)
  }

  async editChannel(channelId, options = {}) {
    let body = {}
    if (options.name) body.name = options.name
    if (options.topic) body.topic = options.topic
    if (options.nsfw !== undefined) body.nsfw = options.nsfw
    if (options.rateLimit !== undefined) body.rate_limit_per_user = options.rateLimit

    return await this.rest.patch("/channels/" + channelId, body)
  }

  async deleteChannel(channelId) {
    return await this.rest.delete("/channels/" + channelId)
  }

  async getChannels(guildId) {
    return await this.rest.get("/guilds/" + guildId + "/channels")
  }

  // ==================== Guild Methods ====================

  async getGuild(guildId) {
    return await this.rest.get("/guilds/" + guildId)
  }

  async getGuilds() {
    return await this.rest.get("/users/@me/guilds")
  }

  async getGuildMembers(guildId, limit = 100, after = null) {
    let endpoint = "/guilds/" + guildId + "/members?limit=" + limit
    if (after) endpoint += "&after=" + after
    return await this.rest.get(endpoint)
  }

  async getGuildMember(guildId, userId) {
    return await this.rest.get("/guilds/" + guildId + "/members/" + userId)
  }

  async addGuildMember(guildId, userId, accessToken, options = {}) {
    let body = { access_token: accessToken }
    if (options.nick) body.nick = options.nick
    if (options.roles) body.roles = options.roles
    if (options.mute !== undefined) body.mute = options.mute
    if (options.deaf !== undefined) body.deaf = options.deaf

    return await this.rest.put("/guilds/" + guildId + "/members/" + userId, body)
  }

  async removeGuildMember(guildId, userId) {
    return await this.rest.delete("/guilds/" + guildId + "/members/" + userId)
  }

  async modifyGuildMember(guildId, userId, options = {}) {
    let body = {}
    if (options.nick !== undefined) body.nick = options.nick
    if (options.roles) body.roles = options.roles
    if (options.mute !== undefined) body.mute = options.mute
    if (options.deaf !== undefined) body.deaf = options.deaf
    if (options.channelId !== undefined) body.channel_id = options.channelId

    return await this.rest.patch("/guilds/" + guildId + "/members/" + userId, body)
  }

  // ==================== Role Methods ====================

  async getRoles(guildId) {
    return await this.rest.get("/guilds/" + guildId + "/roles")
  }

  async createRole(guildId, options = {}) {
    let body = {}
    if (options.name) body.name = options.name
    if (options.color) body.color = options.color
    if (options.hoist !== undefined) body.hoist = options.hoist
    if (options.mentionable !== undefined) body.mentionable = options.mentionable
    if (options.permissions) body.permissions = options.permissions.toString()

    return await this.rest.post("/guilds/" + guildId + "/roles", body)
  }

  async editRole(guildId, roleId, options = {}) {
    let body = {}
    if (options.name) body.name = options.name
    if (options.color) body.color = options.color
    if (options.hoist !== undefined) body.hoist = options.hoist
    if (options.mentionable !== undefined) body.mentionable = options.mentionable
    if (options.permissions) body.permissions = options.permissions.toString()

    return await this.rest.patch("/guilds/" + guildId + "/roles/" + roleId, body)
  }

  async deleteRole(guildId, roleId) {
    return await this.rest.delete("/guilds/" + guildId + "/roles/" + roleId)
  }

  async addRole(guildId, userId, roleId) {
    return await this.rest.put("/guilds/" + guildId + "/members/" + userId + "/roles/" + roleId)
  }

  async removeRole(guildId, userId, roleId) {
    return await this.rest.delete("/guilds/" + guildId + "/members/" + userId + "/roles/" + roleId)
  }

  // ==================== Emoji Methods ====================

  async getEmojis(guildId) {
    return await this.rest.get("/guilds/" + guildId + "/emojis")
  }

  async createEmoji(guildId, name, image) {
    return await this.rest.post("/guilds/" + guildId + "/emojis", {
      name: name,
      image: image,
    })
  }

  async deleteEmoji(guildId, emojiId) {
    return await this.rest.delete("/guilds/" + guildId + "/emojis/" + emojiId)
  }

  // ==================== Webhook Methods ====================

  async createWebhook(channelId, name, avatar = null) {
    let body = { name: name }
    if (avatar) body.avatar = avatar
    return await this.rest.post("/channels/" + channelId + "/webhooks", body)
  }

  async getWebhooks(guildId) {
    return await this.rest.get("/guilds/" + guildId + "/webhooks")
  }

  async deleteWebhook(webhookId) {
    return await this.rest.delete("/webhooks/" + webhookId)
  }

  async executeWebhook(webhookId, webhookToken, content, options = {}) {
    let body = { content: content }
    if (options.username) body.username = options.username
    if (options.avatarUrl) body.avatar_url = options.avatarUrl
    if (options.embeds) body.embeds = options.embeds.map(e => e.build ? e.build() : e)
    if (options.tts) body.tts = true

    return await this.rest.post("/webhooks/" + webhookId + "/" + webhookToken, body)
  }

  // ==================== Interaction Response ====================

  async respondInteraction(interactionId, interactionToken, response) {
    let body = {
      type: response.type || 4,
      data: response.data || {},
    }

    return await http.fetch(
      DISCORD_API + "/interactions/" + interactionId + "/" + interactionToken + "/callback",
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: json.stringify(body),
      }
    )
  }

  async editInteractionResponse(token, response) {
    let body = {}
    if (response.content !== undefined) body.content = response.content
    if (response.embeds) body.embeds = response.embeds.map(e => e.build ? e.build() : e)
    if (response.components) body.components = response.components.map(c => c.build ? c.build() : c)

    return await this.rest.patch("/webhooks/@me/" + token + "/messages/@original", body)
  }

  // ==================== User Methods ====================

  async getUser(userId) {
    return await this.rest.get("/users/" + userId)
  }

  async getMe() {
    return await this.rest.get("/users/@me")
  }

  async editMe(options = {}) {
    let body = {}
    if (options.username) body.username = options.username
    if (options.avatar) body.avatar = options.avatar
    return await this.rest.patch("/users/@me", body)
  }

  // ==================== Voice Methods ====================

  async getVoiceRegions() {
    return await this.rest.get("/voice/regions")
  }

  // ==================== Stage Instance Methods ====================

  async createStageInstance(channelId, topic) {
    return await this.rest.post("/stage-instances", {
      channel_id: channelId,
      topic: topic,
    })
  }

  async getStageInstance(channelId) {
    return await this.rest.get("/stage-instances/" + channelId)
  }

  async deleteStageInstance(channelId) {
    return await this.rest.delete("/stage-instances/" + channelId)
  }
}

