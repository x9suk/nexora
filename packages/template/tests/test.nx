import { describe, it, expect } from "nexora-test";
import { hello } from "../index.nx";

describe("package-name", () => {
  it("returns default greeting", () => {
    expect(hello()).toBe("Hello, World!");
  });

  it("returns custom greeting", () => {
    expect(hello("Nexora")).toBe("Hello, Nexora!");
  });
});
