{
  "server": {
    "port": 3000,
    "host": "0.0.0.0",
    "env": "production"
  },
  "database": {
    "type": "postgresql",
    "host": "localhost",
    "port": 5432,
    "name": "nexora_registry",
    "user": "registry_user",
    "password": "${DB_PASSWORD}",
    "pool": {
      "min": 2,
      "max": 10
    }
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "${REDIS_PASSWORD}",
    "ttl": 3600
  },
  "auth": {
    "jwtSecret": "${JWT_SECRET}",
    "jwtExpiry": "7d",
    "bcryptRounds": 12
  },
  "storage": {
    "github": {
      "enabled": true,
      "token": "${GITHUB_TOKEN}",
      "owner": "nexora-dev"
    },
    "s3": {
      "enabled": true,
      "bucket": "nexora-registry",
      "region": "us-east-1",
      "accessKey": "${AWS_ACCESS_KEY_ID}",
      "secretKey": "${AWS_SECRET_ACCESS_KEY}"
    }
  },
  "cors": {
    "origin": "*",
    "methods": ["GET", "POST", "PUT", "DELETE"]
  },
  "rateLimit": {
    "windowMs": 900000,
    "max": 100
  }
}