{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/vscode-textmate/main/test-cases/schemas/tmlanguage.schema.json",
  "name": "Nexora",
  "scopeName": "source.nexora",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#string_interpolation" },
    { "include": "#numbers" },
    { "include": "#booleans_and_null" },
    { "include": "#keywords" },
    { "include": "#class_keywords" },
    { "include": "#error_keywords" },
    { "include": "#builtin_functions" },
    { "include": "#arrow_functions" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nexora",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nexora",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nexora",
              "match": "\\\\(?:[nrt\\\\\"])"
            },
            {
              "include": "#string_interpolation"
            }
          ]
        }
      ]
    },
    "string_interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.nexora",
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.nexora" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.nexora" }
          },
          "patterns": [
            { "include": "source.nexora" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nexora",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.nexora",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "booleans_and_null": {
      "patterns": [
        {
          "name": "constant.language.boolean.nexora",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.nexora",
          "match": "\\b(null)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nexora",
          "match": "\\b(if|else|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.nexora",
          "match": "\\b(let|func|import)\\b"
        },
        {
          "name": "keyword.other.nexora",
          "match": "\\b(print|input|type_of|assert|test)\\b"
        }
      ]
    },
    "class_keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.class.nexora",
          "match": "\\b(class|new|this|extends|super)\\b"
        }
      ]
    },
    "error_keywords": {
      "patterns": [
        {
          "name": "keyword.control.trycatch.nexora",
          "match": "\\b(try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.control.match.nexora",
          "match": "\\b(match|case)\\b"
        },
        {
          "name": "keyword.other.async.nexora",
          "match": "\\b(async|await)\\b"
        }
      ]
    },
    "builtin_functions": {
      "patterns": [
        {
          "name": "support.function.builtin.nexora",
          "match": "\\b(len|push|pop|sort|reverse|unique|flatten|range|zip|keys|values|entries|map|filter|reduce|split|join|contains|replace|upper|lower|trim|starts_with|ends_with|repeat|char_at|to_chars|lines|index_of|slice|sqrt|pow|abs|floor|ceil|round|min|max|random|sin|cos|tan|log|ln|now|timestamp|sleep|read_file|write_file|append_file|file_exists|read_dir|json_parse|json_stringify|http_get|http_post|html|element|div|span|p|h[1-6]|a|ul|ol|li|table|tr|td|th|button|form|section|nav|header|footer|main|article|aside|render|serve|env|exec_command|str|int|float)\\b"
        }
      ]
    },
    "arrow_functions": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.nexora",
          "match": "=>"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.nexora",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.nexora",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.nexora",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.nexora",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.nexora",
          "match": "(=)"
        },
        {
          "name": "keyword.operator.logical.nexora",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.spread.nexora",
          "match": "\\.\\.\\."
        }
      ]
    }
  }
}
